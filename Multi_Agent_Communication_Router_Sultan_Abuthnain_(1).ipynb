      "source": [
        "# Install the Google GenAI integration\n",
        "!pip install -qU langgraph langchain-google-genai langchain-community langchain-core tiktoken faiss-cpu\n",
        "\n",
        "import os\n",
        "from google.colab import userdata\n",
        "\n",
        "# Request the API Keys from Colab Secrets\n",
        "os.environ[\"GOOGLE_API_KEY\"] = userdata.get('GOOGLE_API_KEY')\n",
        "os.environ[\"LANGSMITH_API_KEY\"] = userdata.get('LANGSMITH_API_KEY')\n",
        "\n",
        "os.environ[\"LANGCHAIN_TRACING_V2\"] = \"true\"\n",
        "os.environ[\"LANGCHAIN_PROJECT\"] = \"Multi-Agent Communication Router_Track_A_Gemini\"\n",
        "\n",
        "print(\"Environment setup complete. LangSmith tracing is active.\")"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "from langchain_core.documents import Document\n",
        "from langchain_google_genai import GoogleGenerativeAIEmbeddings\n",
        "from langchain_community.vectorstores import FAISS\n",
        "from langchain_text_splitters import RecursiveCharacterTextSplitter\n",
        "\n",
        "# 1. Load Documents\n",
        "mock_data = [\n",
        "    Document(page_content=\"Policy: All vacation requests must be submitted via email to HR 14 days in advance.\", metadata={\"source\": \"hr_policy\"}),\n",
        "    Document(page_content=\"Contact Info: HR email is hr@company.com. IT support is it@company.com.\", metadata={\"source\": \"directory\"}),\n",
        "    Document(page_content=\"Meeting Room A is located on the 2nd floor and has a projector.\", metadata={\"source\": \"facilities\"})\n",
        "]\n",
        "\n",
        "# 2. Split Documents\n",
        "text_splitter = RecursiveCharacterTextSplitter(chunk_size=100, chunk_overlap=20)\n",
        "splits = text_splitter.split_documents(mock_data)\n",
        "\n",
        "# 3. Embed and Store\n",
        "embeddings = GoogleGenerativeAIEmbeddings(model=\"gemini-embedding-2-preview\")\n",
        "vectorstore = FAISS.from_documents(splits, embeddings)\n",
        "\n",
        "# 4. Create Retriever\n",
        "retriever = vectorstore.as_retriever(search_kwargs={\"k\": 1})\n",
        "\n",
        "print(f\"RAG Pipeline Ready. Stored {len(splits)} document chunks.\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "YmztL-9Yh3WP",
        "outputId": "ef91fd3d-b94b-482f-a39e-9ea46859a64c"
      },
      "execution_count": 4,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "RAG Pipeline Ready. Stored 3 document chunks.\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "from langgraph.func import task\n",
        "from langgraph.types import interrupt, RetryPolicy\n",
        "from langchain_core.runnables.config import RunnableConfig\n",
        "from langchain_google_genai import ChatGoogleGenerativeAI\n",
        "from langchain_core.messages import HumanMessage, SystemMessage\n",
        "\n",
        "# Initialize the Gemini LLM\n",
        "llm = ChatGoogleGenerativeAI(model=\"gemini-3.5-flash\", temperature=0)\n",
        "\n",
        "rag_retry = RetryPolicy(max_attempts=3, initial_interval=1.0)\n",
        "\n",
        "@task(retry_policy=rag_retry)\n",
        "def retrieve_knowledge(query: str, config: RunnableConfig) -> str:\n",
        "    \"\"\"Retrieves context from the FAISS RAG pipeline.\"\"\"\n",
        "    docs = retriever.invoke(query)\n",
        "    if not docs:\n",
        "        raise ValueError(\"Transient error: Vector store timeout.\")\n",
        "    return docs[0].page_content\n",
        "\n",
        "@task\n",
        "def draft_email(topic: str, recipient: str) -> str:\n",
        "    \"\"\"Requirement 1 (Drafting): Actually calls the LLM to draft the email.\"\"\"\n",
        "    prompt = f\"Draft a concise, professional HR email to {recipient} regarding this policy: {topic}. Do not include a subject line.\"\n",
        "    response = llm.invoke([HumanMessage(content=prompt)])\n",
        "    return response.content\n",
        "\n",
        "@task\n",
        "def send_email_with_approval(draft: str) -> str:\n",
        "    \"\"\"Pauses execution to ask a human for approval before sending.\"\"\"\n",
        "    user_approval = interrupt({\"action\": \"approve_email\", \"draft\": draft})\n",
        "    if user_approval.get(\"approved\") == True:\n",
        "        return \"Email successfully sent to HR.\"\n",
        "    else:\n",
        "        return \"Email sending cancelled by user.\"\n",
        "\n",
        "@task\n",
        "def schedule_calendar_event(title: str, time: str) -> str:\n",
        "    return f\"Calendar event '{title}' scheduled for {time}.\""
      ],
      "metadata": {
        "id": "qiwZ00u1iQn0"
      },
      "execution_count": 10,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from langgraph.func import entrypoint\n",
        "from langgraph.checkpoint.memory import MemorySaver\n",
        "from langgraph.store.memory import InMemoryStore\n",
        "\n",
        "# Initialize short-term (thread) and long-term (cross-thread) memory\n",
        "checkpointer = MemorySaver()\n",
        "store = InMemoryStore() ,
        "\n",
        "# Inject the store into the entrypoint\n",
        "@entrypoint(checkpointer=checkpointer, store=store)\n",
        "def supervisor_agent(messages: list) -> str:\n",
        "    \"\"\"\n",
        "    Supervisor Agent utilizing Gemini for routing and an InMemoryStore for user state.\n",
        "    \"\"\"\n",
        "    user_input = messages[-1].content\n",
        "\n",
        "    user_id = \"sultan_abuthnain\"\n",
        "    namespace = (\"user_profile\", user_id)\n",
        "    profile = store.get(namespace, \"data\")\n",
        "\n",
        "    # If the user doesn't exist in our global database, add them\n",
        "    if not profile:\n",
        "        store.put(namespace, \"data\", {\"department\": \"Computer Science\", \"status\": \"Senior\"})\n",
        "\n",
        "    routing_prompt = f\"\"\"\n",
        "    Analyze this user request: '{user_input}'.\n",
        "    Classify it into EXACTLY ONE of the following categories:\n",
        "    - EMAIL_HR (for vacation, policies, or HR requests)\n",
        "    - CALENDAR (for meetings or scheduling)\n",
        "    - UNKNOWN (if it doesn't fit the above)\n",
        "    Return ONLY the category string.\n",
        "    \"\"\"\n",
        "    response = llm.invoke([\n",
        "        SystemMessage(content=\"You are a strict routing classifier. Output only the exact category name.\"),\n",
        "        HumanMessage(content=routing_prompt)\n",
        "    ])\n",
        "\n",
        "    # Safely convert the content to a string before stripping\n",
        "    decision = str(response.content).strip()\n",
        "\n",
        "    # Route based on the LLM's classification\n",
        "    if \"EMAIL_HR\" in decision:\n",
        "        policy_info = retrieve_knowledge(user_input).result()\n",
        "        draft = draft_email(topic=policy_info, recipient=\"hr@company.com\").result()\n",
        "        return send_email_with_approval(draft).result()\n",
        "\n",
        "    elif \"CALENDAR\" in decision:\n",
        "        return schedule_calendar_event(title=\"Meeting\", time=\"Determined by LLM\").result()\n",
        "\n",
        "    else:\n",
        "        return \"I am currently only equipped to handle HR policy emails and basic scheduling.\""
      ],
      "metadata": {
        "id": "JuZAArjL2QdQ"
      },
      "execution_count": 13,
      "outputs": []
